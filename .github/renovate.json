{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "forkProcessing": "enabled",
    "rollbackPrs": true,
    "stabilityDays": 3,
    "packageRules": [
        {
            "matchUpdateTypes": ["patch", "pin", "rollback"],
            "automerge": true
        },
        {
            "matchManagers": ["dockerfile", "docker-compose"],
            "automerge": false
        }
    ]
}
